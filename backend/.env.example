# =============================================================================
# AI Help Desk — Environment Configuration
# Copy this file to .env and fill in the values for your deployment.
# =============================================================================

# -- Database -----------------------------------------------------------------
# PostgreSQL connection string. Update with your server's IP/hostname.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/helpdesk_db

# -- Server -------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=False

# -- AI Models (Air-gapped local paths) ---------------------------------------
# Path to the multilingual embedding model (relative to backend/ folder)
MODEL_PATH=./local_models/multilingual-e5-base

# -- Offline Mode (HuggingFace) -----------------------------------------------
# CRITICAL: Keep these as "1" on the air-gapped machine to prevent any
# network calls to HuggingFace Hub.
TRANSFORMERS_OFFLINE=1
HF_HUB_OFFLINE=1

# -- Auth (Keycloak) ----------------------------------------------------------
# Set AUTH_ENABLED=False to bypass authentication (development/testing only)
# Set AUTH_ENABLED=True in production with a real Keycloak server
AUTH_ENABLED=False
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=ai-helpdesk
KEYCLOAK_CLIENT_ID=helpdesk-frontend

# -- Voice Layer (STT / TTS) --------------------------------------------------
STT_MODEL_SIZE=medium
STT_DEVICE=cuda          # Use "cuda" if GPU is available, "cpu" otherwise
STT_COMPUTE_TYPE=float16  # Use "float16" for GPU speed, "int8" for CPU

TTS_BACKEND=piper         # "piper" for the bundled offline TTS model

VOICE_SESSION_TTL=1800    # 30 minutes
VOICE_MAX_SVC_RETRIES=3

# -- LLM (vLLM Server) --------------------------------------------------------
# The URL of your locally-running vLLM server (served on the air-gapped LAN)
VLLM_API_URL=http://localhost:8001/v1
VLLM_MODEL_NAME=google/gemma-4-31B-it
VLLM_API_KEY=none

# Set MOCK_LLM=True to skip real LLM calls (returns test data). 
# Set to False in production.
MOCK_LLM=False
